		<!--   =========   Active Object Class   ========  -->
		<ActiveObjectClass>
			<Id>1776879532567</Id>
			<Name><![CDATA[UAV]]></Name>
			<StartupCode><![CDATA[setSpeed(varSpeed);]]></StartupCode>
			<Generic>false</Generic>
			<GenericParameter>
				<Id>1776879532572</Id>
				<Name><![CDATA[1776879532572]]></Name>
				<GenericParameterValue Class="CodeValue">
					<Code><![CDATA[T extends Agent]]></Code>
				</GenericParameterValue>
				<GenericParameterLabel><![CDATA[Generic parameter:]]></GenericParameterLabel>
			</GenericParameter>
			<FlowChartsUsage>ENTITY</FlowChartsUsage>
			<SamplesToKeep>100</SamplesToKeep>
			<LimitNumberOfArrayElements>false</LimitNumberOfArrayElements>
			<ElementsLimitValue>100</ElementsLimitValue>
			<MakeDefaultViewArea>true</MakeDefaultViewArea>
			<SceneGridColor/>
			<SceneBackgroundColor>-4144960</SceneBackgroundColor>
			<SceneSkybox>null</SceneSkybox>
			<AgentProperties>
				<EnvironmentDefinesInitialLocation>true</EnvironmentDefinesInitialLocation>
				<RotateAnimationTowardsMovement>true</RotateAnimationTowardsMovement>
				<RotateAnimationVertically>false</RotateAnimationVertically>
				<VelocityCode Class="CodeUnitValue">
					<Code><![CDATA[10]]></Code>
					<Unit Class="SpeedUnits"><![CDATA[MPS]]></Unit>
				</VelocityCode>
				<OnArrival><![CDATA[if (varExploring) {
	fnPickWaypoint();
	double tx = varCandX[varChosenIdx];
	double ty = varCandY[varChosenIdx];
	if (Math.hypot(tx - getX(), ty - getY()) < 0.5) {
		// Avoid zero-distance moveTo which can recurse into OnArrival
		tx = getX() + 0.5;
		ty = getY() + 0.5;
	}
	moveTo(tx, ty, varSpeed);
} else if (varMovingToCharger) {
    varMovingToCharger = false;
} else {
    // Arrived while Exploit: re-sense, confirm victim, then move away immediately
    fnSenseNow();
    fnSenseNowGrid();
    if (varTargetConfidence >= varDetectionThreshold) varVictimsConfirmed = varVictimsConfirmed + 1;
    // pick a new waypoint and move away so UAV doesn't idle on top of the victim
    fnPickWaypoint();
    // add a tiny offset to avoid zero-distance move
    moveTo(varCandX[varChosenIdx] + 0.1, varCandY[varChosenIdx] + 0.1, varSpeed);
}]]></OnArrival>
				<PhysicalLength Class="CodeUnitValue">
