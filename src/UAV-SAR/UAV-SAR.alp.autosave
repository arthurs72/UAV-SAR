        && varQueuedTargetX < 0) {
    varQueuedTargetX = varTargetX;
    varQueuedTargetY = varTargetY;
}
varBatteryLevel = Math.max(0, varBatteryLevel - varBatteryDepletionRate * 0.5);
if (batteryText != null) {
    batteryText.setText(String.format("%.0f%%", varBatteryLevel));
}]]></Action>
