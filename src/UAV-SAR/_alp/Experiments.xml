		<InitialSetupCode>new java.io.File("experiments").mkdirs();

long runTime;
java.text.SimpleDateFormat sdf = new java.text.SimpleDateFormat("yyyyMMddHHmmssSSS");

// Format the initial date string (Outputs exactly 17 digits)
String runId = "";
String expDir = "";

// Synchronize on the experiment class object to prevent thread collision
synchronized(this.getClass()) {
    runTime = java.lang.System.currentTimeMillis();
    runId = sdf.format(new java.util.Date(runTime));
    expDir = "experiments/" + runId;

    // Increment and sleep if the directory already exists
    while (new java.io.File(expDir).exists()) {
        try {
            java.lang.Thread.sleep(1);
        } catch (Exception e) {}
        runTime = java.lang.System.currentTimeMillis();
        runId = sdf.format(new java.util.Date(runTime));
        expDir = "experiments/" + runId;
    }
    
    // Create the directory immediately while inside the locked block
    new java.io.File(expDir).mkdirs();
}

System.setProperty("uavsar.exp.dir", expDir);

try {
    java.io.FileWriter fw = new java.io.FileWriter(expDir + "/run_summary.csv", false);
    fw.write("seed,sensorRange,acoCandidateCount,acoStepLength,acoAlpha,acoBeta,converged,convergenceTime,victimsFound\n");
    fw.close();

    java.io.FileWriter fw2 = new java.io.FileWriter(expDir + "/victim_log.csv", false);
    fw2.write("seed,sensorRange,acoCandidateCount,acoStepLength,acoAlpha,acoBeta,victimIdx,uavIdx,foundTime,x,y\n");
    fw2.close();
} catch (Exception e) {
    traceln("Header write error: " + e.getMessage());
