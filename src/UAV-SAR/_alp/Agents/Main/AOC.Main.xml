	<Name><![CDATA[Main]]></Name>
	<StartupCode><![CDATA[// Seed first so all randomness in this run is reproducible
getDefaultRandomGenerator().setSeed(varSeed);

// Push experiment parameters down to every UAV
for (UAV u : uavs) {
    u.varSensorRange       = varSensorRange;
    u.varAcoCandidateCount = varAcoCandidateCount;
    u.varAcoStepLength     = varAcoStepLength;
    u.varAcoAlpha          = varAcoAlpha;
    u.varAcoBeta           = varAcoBeta;
    u.varBatteryLevel      = uniform(20, 80);
}

// Place victims after seed is set so placement is reproducible
fnPlaceVictimsGMM();]]></StartupCode>
